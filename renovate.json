{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "security:openssf-scorecard",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "baseBranches": ["dev"],
  "enabledManagers": ["pep621", "github-actions"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "5 days",
  "schedule": ["after 9am and before 6pm every weekday"],
  "timezone": "Europe/Paris",
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "packageRules": [
    {
      "description": "API layer (fastapi, uvicorn, pydantic, httpx): separate PR",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["fastapi", "uvicorn", "pydantic", "httpx", "python-multipart"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python API layer (minor/patch)"
    },
    {
      "description": "Data layer (sqlalchemy, alembic, pandas, numpy, polars, pyarrow): separate PR",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["SQLAlchemy", "alembic", "pandas", "numpy", "numexpr", "polars", "pyarrow", "tables", "openpyxl", "xlsxwriter"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python data layer (minor/patch)"
    },
    {
      "description": "Infra layer (celery, redis, gunicorn, psycopg2): separate PR",
      "matchManagers": ["pep621"],
      "matchPackageNames": ["celery", "redis", "gunicorn", "psycopg2-binary", "prometheus-client"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python infra layer (minor/patch)"
    },
    {
      "description": "Remaining Python prod minor/patch updates",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python other dependencies (minor/patch)"
    },
    {
      "description": "Group Python dev dependencies minor/patch updates",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python dev dependencies (minor/patch)"
    },
    {
      "description": "Major updates: one PR per package, require dashboard approval",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "minimumReleaseAge": "14 days",
      "labels": ["dependencies", "breaking"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Security updates bypass schedule and release age",
      "matchCategories": ["security"],
      "schedule": ["at any time"],
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "labels": ["dependencies", "security"]
    },
    {
      "description": "Internal Antares packages: require dashboard approval",
      "matchPackagePrefixes": ["Antares-", "antares-"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "internal"]
    },
    {
      "description": "Lock file maintenance weekly",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "schedule": ["before 9am on monday"]
    }
  ]
}